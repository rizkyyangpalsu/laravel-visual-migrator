{
    "name": "ekosuprianto96/laravel-visual-migrator",
    "description": "Visual Schema Designer for Laravel Migrations (powered by Mongo Diagram)",
    "version": "2.6.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Eko Suprianto",
            "email": "ekosuprianto96@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ekosuprianto96\\VisualMigrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ekosuprianto96\\VisualMigrator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ekosuprianto96\\VisualMigrator\\VisualMigratorServiceProvider"
            ]
        }
    }
}